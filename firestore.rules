rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    // Rules for driver_settings
    match /driver_settings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Rules for call_analyses
    match /call_analyses/{analysisId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    // Rules for completed_rides
    match /completed_rides/{rideId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    // Rules for neighborhood_insights
    match /neighborhood_insights/{insightId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    // Rules for users
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
